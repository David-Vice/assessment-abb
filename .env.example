# --- OpenAI ---
OPENAI_API_KEY=sk-your-key-here
CHAT_MODEL=gpt-4o
AUX_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# --- Retrieval / RAG ---
RETRIEVAL_CANDIDATES=40
RETRIEVAL_TOP_K=6
CONTEXT_TOKEN_BUDGET=8000
# Multi-turn memory: load recent turns from chat_logs to rewrite follow-ups.
CHAT_MEMORY_ENABLED=true

# --- Reranking (optional precision boost; local BGE cross-encoder) ---
# Two switches: INSTALL_RERANK (build) installs torch + bakes the model into the
# chat image; RERANK_ENABLED (runtime) turns it on. Both must be true to rerank.
# Off by default keeps images lean; hybrid search alone answers well. The
# cross-encoder is CPU-bound — fast on GPU, slow on CPU (lower RETRIEVAL_CANDIDATES
# to ~16 if enabling on CPU).
INSTALL_RERANK=false
RERANK_ENABLED=false
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# --- Database (Postgres + pgvector) ---
# DATABASE_URL uses the in-container host `postgres` (services talk over the
# compose network). For host-side scripts, override with localhost:<host-port>.
DATABASE_URL=postgresql+psycopg://abb:abb@postgres:5432/abb_rag
POSTGRES_USER=abb
POSTGRES_PASSWORD=abb
POSTGRES_DB=abb_rag
# Host port mapped to the container's 5432. Override (e.g. 5433) if a native
# Postgres already occupies 5432 on the host. (Container-internal DATABASE_URL is
# unaffected — services always reach Postgres on 5432 over the compose network.)
POSTGRES_HOST_PORT=5432

# --- Redis (queue / cache / rate-limit) ---
REDIS_URL=redis://redis:6379/0

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Scraper (Playwright crawl over the sitemap) ---
SCRAPE_START_URL=https://abb-bank.az/

# --- Service URLs (frontend → backend) ---
INGESTION_URL=http://localhost:8001
CHAT_URL=http://localhost:8002
ANALYTICS_URL=http://localhost:8003

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173
