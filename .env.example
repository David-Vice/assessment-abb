# --- OpenAI ---
OPENAI_API_KEY=sk-your-key-here
CHAT_MODEL=gpt-4o
AUX_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# --- Retrieval / RAG ---
RETRIEVAL_CANDIDATES=40
RETRIEVAL_TOP_K=6
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3
CONTEXT_TOKEN_BUDGET=8000

# --- Database (Postgres + pgvector) ---
# DATABASE_URL uses the in-container host `postgres` (services talk over the
# compose network). For host-side scripts, override with localhost:<host-port>.
DATABASE_URL=postgresql+psycopg://abb:abb@postgres:5432/abb_rag
POSTGRES_USER=abb
POSTGRES_PASSWORD=abb
POSTGRES_DB=abb_rag
# Host port mapped to the container's 5432. Override (e.g. 5433) if a native
# Postgres already occupies 5432 on the host.
POSTGRES_HOST_PORT=5432

# --- Redis (queue / cache / rate-limit) ---
REDIS_URL=redis://redis:6379/0

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Scraper (Playwright crawl over the sitemap) ---
SCRAPE_START_URL=https://abb-bank.az/

# --- Service URLs (frontend → backend) ---
INGESTION_URL=http://localhost:8001
CHAT_URL=http://localhost:8002
ANALYTICS_URL=http://localhost:8003

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173
